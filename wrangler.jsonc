{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "anthropic-feedback-batch-demo",
	"main": "src/index.ts",
	"compatibility_date": "2026-04-20",
	"triggers": {
		"crons": ["* * * * *"]
	},
	"queues": {
		"producers": [
			{
				"binding": "FEEDBACK_QUEUE",
				"queue": "feedback-analysis-queue"
			}
		],
		"consumers": [
			{
				"queue": "feedback-analysis-queue",
				"max_batch_size": 3,
				"max_batch_timeout": 60,
				"max_retries": 3,
				"dead_letter_queue": "feedback-analysis-dlq"
			}
		]
	},
	"d1_databases": [
		{
			"binding": "FEEDBACK_DB",
			"database_name": "feedback-analysis-db",
			"database_id": "73d200aa-e226-4652-844e-2a8d2ee69b06",
			"migrations_dir": "migrations"
		}
	]
}
